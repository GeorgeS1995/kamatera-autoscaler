# Copy this file to `.env` (which is gitignored) and fill in real values
# for local development. The binary reads only environment variables —
# the Makefile target `make run-local` sources this file before launch.

# Kamatera REST API credentials. Obtained from Kamatera Console → API.
KAMATERA_API_CLIENT_ID=replace_me
KAMATERA_API_SECRET=replace_me

# Cluster join token used by your cloud-init template (e.g. K3S_TOKEN for k3s).
# Whatever variable your template references via {{ .JoinToken }} maps here.
AUTOSCALER_JOIN_TOKEN=replace_me

# SSH public key injected into every newly provisioned VM (so you can ssh in
# for debugging if cloud-init fails).
SSH_PUB_KEY="ssh-ed25519 AAAA... your-comment"

# Path to the YAML pools config. In a Pod this is typically a ConfigMap mount.
AUTOSCALER_CONFIG=./examples/pools.yaml

# Log verbosity: debug, info, warn, error.
LOG_LEVEL=info

# When running outside the cluster, point at a kubeconfig with permission
# to list pods/nodes and evict pods. Inside a Pod this is auto-detected.
KUBECONFIG=
